# Copy this file to .env locally (or paste into Railway's "Variables" tab).
# DO NOT commit .env or the real values. Only this template lives in git.

# --- BigQuery service account ---
# Paste the FULL contents of the service-account JSON key as a single line.
# On Railway, paste the JSON into the variable value as-is (Railway accepts
# multi-line values for env vars).
GOOGLE_APPLICATION_CREDENTIALS_JSON=

# --- Authentication ---
# REQUIRE_AUTH defaults to true when RAILWAY_ENVIRONMENT is set, false otherwise.
# Override only if you want to force one or the other.
# REQUIRE_AUTH=true

# OAuth 2.0 credentials from Google Cloud Console (APIs & Services -> Credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# The exact URL Google should redirect back to after login.
# Format: https://<your-railway-domain>/oauth2callback
AUTH_REDIRECT_URI=

# Random 32+ character string. Generate with:  python -c "import secrets; print(secrets.token_urlsafe(48))"
AUTH_COOKIE_SECRET=

# --- Data source lockdown ---
# When true on a deployed instance, users see the data loaded automatically
# from the table below and can't change the connection. Defaults to true
# when RAILWAY_ENVIRONMENT is set, false locally.
LOCK_DATA_SOURCE=true

# Full BigQuery table reference (project.dataset.table)
BQ_DEFAULT_TABLE=mrq-data.dbt.attribution_spend_metrics

# Date column for the time-window filter
BQ_DEFAULT_DATE_COLUMN=date

# Days of history to pull. 0 = full table (use with caution on large tables).
BQ_DEFAULT_LOOKBACK_DAYS=365

# --- Optional ---
# Comma-separated list of allowed email domains. Defaults to mrq.com.
# ALLOWED_EMAIL_DOMAINS=mrq.com

# Google Workspace hosted domain hint (Google login UX optimisation).
# OAUTH_HOSTED_DOMAIN=mrq.com
